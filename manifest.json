{
  "manifest_version": 2,
  "name": "WA Custom Sound",
  "version": "1.0",
  "description": "Custom WhatsApp notification sounds",
  "author": "Repulserator",
  "permissions": [
    "https://web.whatsapp.com/*",
    "storage"
  ],

  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "browser_action": {
  "default_title": "WA Custom Sound",
  "default_popup": "popup.html",
  "default_icon": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "wa-custom-sound@repulserator",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}